# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/mailtracker
USE_MEMORY_DB=true

# JWT Configuration
JWT_SECRET=supersecretjwtkey

# Email Configuration (Gmail) — use a Google App Password, not your account password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=ryho fqcr rnoz jjwz

# Server Configuration
PORT=5002
# Public URL for open/click tracking (auto-set when USE_TRACKING_TUNNEL=true)
BACKEND_URL=http://localhost:5002
# Auto-start localtunnel for real Gmail tracking in development
USE_TRACKING_TUNNEL=true

# SMTP Configuration — set false to send real emails via Gmail
SKIP_SMTP=false

# Node Environment
NODE_ENV=development

NGROK_URL=https://xxxx.ngrok-free.app